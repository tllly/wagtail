# Django Security
DJANGO_SECRET_KEY=找一个随机的长字符串填在这里
DJANGO_ALLOWED_HOSTS=www.yourdomain.com,yourdomain.com

# Cloudflare R2 Credentials
R2_ACCESS_KEY_ID=从Cloudflare拿到的Access Key
R2_SECRET_ACCESS_KEY=从Cloudflare拿到的Secret Access Key
R2_BUCKET_NAME=mysite-media
R2_ENDPOINT_URL=https://<你的账户ID>.r2.cloudflarestorage.com
R2_CUSTOM_DOMAIN=images.yourdomain.com

# Database (初期可以用SQLite，后期建议换Postgres)
# DATABASE_URL=postgres://user:password@localhost:5432/dbname
